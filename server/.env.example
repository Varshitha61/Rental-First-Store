# MongoDB connection string (required)
# Local:  mongodb://localhost:27017/borrow
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/borrow
MONGO_URI=mongodb://localhost:27017/borrow

# Express server port (defaults to 5000 if not set)
PORT=5000

# Secret used to sign JWT tokens (used in future auth feature)
JWT_SECRET=your_super_secret_key_here
